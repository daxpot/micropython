# DooiRobot board: custom SDIO pin mapping for C6 WiFi module.
# Overrides the default P4 Function Board pin assignments.

# Use custom board (not the default Function EV Board)
CONFIG_ESP_HOSTED_P4_DEV_BOARD_FUNC_BOARD=n
CONFIG_ESP_HOSTED_P4_DEV_BOARD_NONE=y

# DooiRobot SDIO pin mapping (from manufacturer's config.json)
CONFIG_ESP_HOSTED_SDIO_HOST_INTERFACE=y
CONFIG_ESP_HOSTED_SDIO_SLOT_1=y
CONFIG_ESP_HOSTED_SDIO_4_BIT_BUS=y
CONFIG_ESP_HOSTED_SDIO_CLOCK_FREQ_KHZ=40000
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CMD_SLOT_1=48
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_CLK_SLOT_1=47
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D0_SLOT_1=46
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D1_4BIT_BUS_SLOT_1=45
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D2_4BIT_BUS_SLOT_1=44
CONFIG_ESP_HOSTED_PRIV_SDIO_PIN_D3_4BIT_BUS_SLOT_1=43
CONFIG_ESP_HOSTED_SDIO_GPIO_RESET_SLAVE=42
CONFIG_ESP_HOSTED_SDIO_RESET_ACTIVE_HIGH=y
CONFIG_ESP_HOSTED_SDIO_RESET_DELAY_MS=1500

# Slave target
CONFIG_SLAVE_IDF_TARGET_ESP32C6=y
